{
  "name": "mindfirst-desktop",
  "version": "1.0.0",
  "description": "MindFirst, AI Usage Monitor for Mac",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac"
  },
  "build": {
    "appId": "com.mindfirst.desktop",
    "productName": "MindFirst",
    "copyright": "MindFirst",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**",
      "renderer/**",
      "assets/**"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "identity": null,
      "target": [
        { "target": "dmg", "arch": ["universal"] }
      ],
      "extendInfo": {
        "LSUIElement": true,
        "NSAppleEventsUsageDescription": "MindFirst monitors which app is in focus to track your AI usage time.",
        "NSUserNotificationAlertStyle": "alert"
      }
    },
    "dmg": {
      "title": "MindFirst",
      "background": null,
      "window": { "width": 540, "height": 380 }
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1"
  }
}
